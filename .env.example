# Copy this file to .env (or export these as real environment variables) before running locally.

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=healthmate_ai
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key_here

# --- Server ---
PORT=8080
